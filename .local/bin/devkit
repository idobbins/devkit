#!/usr/bin/env bash
set -euo pipefail

DEVKIT_HOME="${DEVKIT_HOME:-$HOME/.devkit}"
DEV_HOME="${DEV_HOME:-$HOME/dev}"

usage() {
  cat <<'EOF'
Usage: devkit COMMAND [ARGS]

Workstation commands:
  apply              Apply this machine's Nix config
  update             Pull ~/.devkit and apply it
  edit               Open ~/.devkit in $EDITOR
  status             Show devkit repo/platform status
  doctor             Check required tools and paths
  gc                 Run Nix garbage collection
  path               Print the devkit repo path
  pi-sync            Register ~/.devkit as a pi package

Project helpers:
  project-info [DIR] Show detected project commands/tools
  attach [--keep] [--open] HOST REMOTE_DIR
                     Forward a remote project's manifest ports to local localhost

Examples:
  devkit update
  devkit apply
  devkit project-info ~/dev/i7/notoil
  devkit attach --keep --open fort /home/ian/project
EOF
}

log() { printf '==> %s\n' "$*"; }
warn() { printf 'WARN: %s\n' "$*" >&2; }
die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

require_repo() {
  [[ -d "$DEVKIT_HOME/.git" ]] || die "devkit repo not found at $DEVKIT_HOME"
}

is_nixos() { [[ -e /etc/NIXOS ]]; }

target_name() {
  case "$(uname -s)" in
    Darwin) printf 'macos' ;;
    Linux)
      if is_nixos; then printf 'nixos'; else printf 'linux'; fi
      ;;
    *) die "unsupported OS: $(uname -s)" ;;
  esac
}

apply_config() {
  require_repo
  have nix || die "nix is not installed or not on PATH"

  target="$(target_name)"
  case "$target" in
    macos)
      log "Applying nix-darwin config: $DEVKIT_HOME#macos"
      if [[ "${EUID:-$(id -u)}" -eq 0 ]]; then
        nix --option nix-path "" run nix-darwin -- switch --flake "$DEVKIT_HOME#macos" --impure
      else
        nix_bin="$(command -v nix)"
        sudo env \
          USER="$USER" \
          LOGNAME="$USER" \
          HOME=/var/root \
          XDG_CACHE_HOME=/var/root/.cache \
          NIX_PATH= \
          DEVKIT_USER_HOME="$HOME" \
          DEVKIT_HOME="$DEVKIT_HOME" \
          "$nix_bin" --option nix-path "" run nix-darwin -- switch --flake "$DEVKIT_HOME#macos" --impure
      fi
      ;;
    linux)
      log "Applying Home Manager config: $DEVKIT_HOME#linux"
      nix --option nix-path "" run home-manager -- switch --flake "$DEVKIT_HOME#linux" --impure
      ;;
    nixos)
      log "Applying NixOS config: $DEVKIT_HOME#nixos"
      sudo nixos-rebuild switch --flake "$DEVKIT_HOME#nixos"
      ;;
  esac
}

update_config() {
  require_repo
  log "Updating $DEVKIT_HOME"
  git -C "$DEVKIT_HOME" pull --ff-only
  apply_config
}

edit_config() {
  require_repo
  editor="${EDITOR:-nvim}"
  have "$editor" || editor="vi"
  exec "$editor" "$DEVKIT_HOME"
}

status_config() {
  require_repo
  printf 'Devkit: %s\n' "$DEVKIT_HOME"
  printf 'Target: %s\n' "$(target_name)"
  printf 'Nix:    '
  if have nix; then nix --version; else printf 'missing\n'; fi
  printf '\nRepo status:\n'
  git -C "$DEVKIT_HOME" status --short --branch
  printf '\nLast commit:\n'
  git -C "$DEVKIT_HOME" log -1 --oneline
}

doctor() {
  failures=0
  check() {
    if eval "$2" >/dev/null 2>&1; then
      printf '✓ %s\n' "$1"
    else
      printf '✗ %s\n' "$1"
      failures=$((failures + 1))
    fi
  }

  check "devkit repo exists at $DEVKIT_HOME" "test -d '$DEVKIT_HOME/.git'"
  check "git is available" "command -v git"
  check "nix is available" "command -v nix"
  check "flake.nix exists" "test -f '$DEVKIT_HOME/flake.nix'"

  case "$(uname -s)" in
    Darwin) check "macOS target is selected" "true" ;;
    Linux)
      if is_nixos; then
        check "NixOS target is selected" "true"
        check "nixos-rebuild is available" "command -v nixos-rebuild"
      else
        check "Linux Home Manager target is selected" "true"
      fi
      ;;
    *) check "supported OS" "false" ;;
  esac

  if [[ -d "$DEVKIT_HOME/.git" ]]; then
    if [[ -n "$(git -C "$DEVKIT_HOME" status --porcelain)" ]]; then
      warn "devkit repo has local changes"
    else
      printf '✓ devkit repo is clean\n'
    fi
  fi

  [[ "$failures" -eq 0 ]] || exit 1
}

gc_nix() {
  have nix || die "nix is not installed or not on PATH"
  nix store gc
}

pi_sync() {
  require_repo
  have jq || die "jq is required for pi-sync"

  settings_dir="$HOME/.pi/agent"
  settings_file="$settings_dir/settings.json"
  mkdir -p "$settings_dir"
  [[ -f "$settings_file" ]] || printf '{}\n' > "$settings_file"

  tmp="$(mktemp)"
  jq --arg pkg "$DEVKIT_HOME" '
    .packages = (((.packages // []) | map(select(. != $pkg))) + [$pkg])
  ' "$settings_file" > "$tmp"
  mv "$tmp" "$settings_file"

  log "Registered devkit pi package in $settings_file"
  log "Run /reload in pi, or restart pi, to load extensions"
}

attach_project() {
  keep=0
  open=0
  manifest=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -k|--keep) keep=1; shift ;;
      --open) open=1; shift ;;
      --manifest)
        [[ $# -ge 2 ]] || die "--manifest requires a remote manifest path"
        manifest="$2"; shift 2 ;;
      -h|--help)
        cat <<'EOF'
Usage: devkit attach [--keep] [--open] [--manifest REMOTE_MANIFEST] HOST REMOTE_DIR

Forward ports from a remote project manifest into this machine's localhost.
Defaults to REMOTE_DIR/.fundlaunch/manifest.json, falling back to
REMOTE_DIR/.fundlaunch/tunnels.json and REMOTE_DIR/.devkit/tunnels.json.

Examples:
  devkit attach fort /home/ian/project
  devkit attach --keep --open fort /home/ian/project
  devkit attach --manifest /home/ian/project/.fundlaunch/manifest.json fort /home/ian/project
EOF
        return 0 ;;
      --) shift; break ;;
      -*) die "unknown attach option: $1" ;;
      *) break ;;
    esac
  done

  [[ $# -eq 2 ]] || die "usage: devkit attach [--keep] [--open] HOST REMOTE_DIR"
  host="$1"
  remote_dir="${2%/}"

  have ssh || die "ssh is required"
  have tunnel || die "tunnel is required; run 'devkit apply' to install it"

  if [[ -z "$manifest" ]]; then
    manifest="$(
      ssh "$host" sh -s -- "$remote_dir" <<'EOF'
set -eu
root="$1"
for candidate in \
  "$root/.fundlaunch/manifest.json" \
  "$root/.fundlaunch/tunnels.json" \
  "$root/.devkit/tunnels.json" \
  "$root/tunnels.json"; do
  if [ -f "$candidate" ]; then
    printf '%s\n' "$candidate"
    exit 0
  fi
done
exit 1
EOF
    )" || die "no tunnel manifest found on $host under $remote_dir"
  fi

  log "Attaching $host:$remote_dir"
  log "Manifest: $manifest"

  if [[ "$open" -eq 1 ]]; then
    url="$(ssh "$host" sh -c 'jq -r '\''(.urls.frontend // .urls.app // empty)'\'' "$1" 2>/dev/null' sh "$manifest" || true)"
    if [[ -n "$url" && "$url" != "null" ]]; then
      (
        sleep 2
        case "$(uname -s)" in
          Darwin) open "$url" >/dev/null 2>&1 || true ;;
          Linux) xdg-open "$url" >/dev/null 2>&1 || true ;;
        esac
      ) &
    fi
  fi

  args=()
  [[ "$keep" -eq 1 ]] && args+=(--keep)
  exec tunnel "${args[@]}" "$host" --remote-manifest "$manifest"
}

project_info() {
  dir="${1:-$PWD}"
  [[ -d "$dir" ]] || die "not a directory: $dir"

  printf 'Project: %s\n' "$dir"

  if git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf 'Git:     '
    git -C "$dir" status --short --branch | head -1
  fi

  if [[ -f "$dir/.envrc" ]]; then
    printf '%s\n' "Env:     .envrc present; run \`direnv allow\` once if it is blocked"
  fi

  if [[ -f "$dir/flake.nix" ]]; then
    printf '%s\n' "Nix:     flake.nix present; use \`nix develop\` or direnv with \`use flake\`"
  fi

  if [[ -f "$dir/package.json" ]]; then
    printf 'Node:    package.json present\n'
    if have jq; then
      scripts="$(jq -r '.scripts // {} | keys | join(", ")' "$dir/package.json" 2>/dev/null || true)"
      [[ -n "$scripts" ]] && printf 'Scripts: %s\n' "$scripts"
    else
      printf 'Try:     pnpm install && pnpm dev\n'
    fi
  fi

  [[ -f "$dir/pyproject.toml" ]] && printf '%s\n' "Python:  pyproject.toml present; try \`uv sync\` or \`uv run ...\`"
  [[ -f "$dir/requirements.txt" ]] && printf '%s\n' "Python:  requirements.txt present; try \`uv venv && uv pip install -r requirements.txt\`"
  [[ -f "$dir/Cargo.toml" ]] && printf '%s\n' "Rust:    Cargo.toml present; try \`cargo build\` or \`cargo run\`"
  [[ -f "$dir/Makefile" || -f "$dir/makefile" ]] && printf '%s\n' "Make:    Makefile present; try \`make help\` or \`make\`"

  return 0
}

cmd="${1:-}"
case "$cmd" in
  apply) shift; apply_config "$@" ;;
  update) shift; update_config "$@" ;;
  edit) shift; edit_config "$@" ;;
  status) shift; status_config "$@" ;;
  doctor) shift; doctor "$@" ;;
  gc) shift; gc_nix "$@" ;;
  path) shift; printf '%s\n' "$DEVKIT_HOME" ;;
  pi-sync) shift; pi_sync "$@" ;;
  attach) shift; attach_project "$@" ;;
  project-info) shift; project_info "$@" ;;
  -h|--help|help|'') usage ;;
  *) usage >&2; die "unknown command: $cmd" ;;
esac
